# Database — local Docker Postgres uses POSTGRES_PASSWORD below.
# For Railway/hosted Postgres, set DATABASE_URL instead (and point backend at it).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
POSTGRES_PASSWORD=recalls_dev_password

# LLM chat
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash

# Text embeddings for RAG (separate from LLM_PROVIDER)
# google = models/text-embedding-004, same GOOGLE_API_KEY as chat (default)
# openai = text-embedding-3-small, requires OPENAI_API_KEY
EMBEDDING_PROVIDER=google
# Optional override — defaults are chosen from EMBEDDING_PROVIDER
# EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=1536

# Google — chat + embeddings + image description (one key)
GOOGLE_API_KEY=AIza...

# OpenAI — only if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Azure OpenAI / Azure AI Foundry (LLM_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Anthropic (LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# Groq (LLM_PROVIDER=groq)
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# OpenRouter (LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=qwen/qwen2.5-72b-instruct

# Ollama (LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# Image Search — Jina CLIP (optional)
# JINA_API_KEY=jina_...

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
ADMIN_API_KEY=dev-admin-key
INGESTION_SCHEDULE_HOURS=6
