# Database
POSTGRES_PASSWORD=recalls_dev_password

# LLM Provider — change LLM_PROVIDER to switch: openai | google | anthropic | groq | openrouter | ollama
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI — required for text embeddings (RAG search) regardless of LLM_PROVIDER
# Also used as LLM when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Google Gemini (LLM_PROVIDER=google) — recommended, generous free tier
# Get key: aistudio.google.com
GOOGLE_API_KEY=AIza...

# Anthropic (LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# Groq (LLM_PROVIDER=groq) — fastest inference, free tier
# Get key: console.groq.com
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# OpenRouter (LLM_PROVIDER=openrouter) — access Qwen, Kimi k2, Mistral, etc.
# Get key: openrouter.ai
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=qwen/qwen2.5-72b-instruct

# Ollama (LLM_PROVIDER=ollama) — self-hosted, no API key
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# Image Search — set JINA_API_KEY to enable visual product search (jina.ai)
# Without this key, image upload is shown as "coming soon" and no image embeddings are created.
# JINA_API_KEY=jina_...

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Ingestion schedule (hours between full re-sync)
INGESTION_SCHEDULE_HOURS=6
