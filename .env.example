# Database
POSTGRES_PASSWORD=recalls_dev_password

# LLM Provider — change LLM_PROVIDER to switch: openai | anthropic | groq | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic (LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# Groq (LLM_PROVIDER=groq)
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# Ollama (LLM_PROVIDER=ollama) — self-hosted, no API key
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# Image Search — set JINA_API_KEY to enable visual product search (jina.ai)
# Without this key, image upload is shown as "coming soon" and no image embeddings are created.
# JINA_API_KEY=jina_...

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Ingestion schedule (hours between full re-sync)
INGESTION_SCHEDULE_HOURS=6
